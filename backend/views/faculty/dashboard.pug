extends ../layout

block body
  include ../partials/topbar
  .wrapper
    include ../partials/sidebar-faculty
    .main
      if success_msg.length
        .msg-success= success_msg
      if error_msg.length
        .msg-error= error_msg
      .page-heading Faculty Dashboard
      .stat-row
        .stat-box
          span.stat-num= stats.total
          span.stat-label Total Applications
        .stat-box.pending
          span.stat-num= stats.pending
          span.stat-label Pending
        .stat-box.approved
          span.stat-num= stats.approved
          span.stat-label Approved
        .stat-box.rejected
          span.stat-num= stats.rejected
          span.stat-label Rejected
      p
        a.btn.btn-primary(href="/faculty/apply")  Apply for New Leave
      hr
      h3(style="color:#003399; margin:0 0 10px") Recent Applications
      if leaves.length === 0
        p.text-muted No applications found. Click "Apply for New Leave" to get started.
      else
        .table-scroll
          table
            thead
              tr
                th # 
                th Leave Type
                th From
                th To
                th Status
                th Action
            tbody
              each leave, i in leaves
                tr(class=leave.isUrgent ? 'urgent-row' : '')
                  td= i + 1
                  td
                    if leave.isUrgent
                      span.badge.badge-urgent URGENT &nbsp;
                    | #{leave.leaveType}
                  td= new Date(leave.startDate).toLocaleDateString('en-IN')
                  td= new Date(leave.endDate).toLocaleDateString('en-IN')
                  
                  td
                    span(class="badge badge-" + leave.status.toLowerCase())= leave.status
                  td
                    a.btn.btn-default.btn-sm(href="/faculty/leave/" + leave._id) View
      hr
      p
        a.btn.btn-primary(href="/faculty/my-leaves") View all my applications
  .site-footer
    | Faculty Leave Management System &copy; 2024
