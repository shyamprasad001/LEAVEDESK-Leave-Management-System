extends ../layout

block body
  include ../partials/topbar
  .wrapper
    include ../partials/sidebar-hod
    .main
      if success_msg.length
        .msg-success= success_msg
      if error_msg.length
        .msg-error= error_msg
      .page-heading HOD Dashboard — #{user.department}
      .stat-row
        .stat-box
          span.stat-num= stats.total
          span.stat-label Total Requests
        .stat-box.pending
          span.stat-num= stats.pending
          span.stat-label Pending
        .stat-box.approved
          span.stat-num= stats.approved
          span.stat-label Approved
        .stat-box.rejected
          span.stat-num= stats.rejected
          span.stat-label Rejected
        .stat-box.faculty-count
          span.stat-num= stats.totalFaculty
          span.stat-label Faculty Members
      p
        a.btn.btn-primary(href="/hod/leave-requests?status=Pending") View Pending Requests
        |  &nbsp;
        a.btn.btn-default(href="/hod/leave-requests") All Requests
      hr
      h3(style="color:#003399; margin:0 0 10px") Recent Leave Requests
      if recentLeaves.length === 0
        p.text-muted No leave requests found in your department.
      else
        .table-scroll
          table
            thead
              tr
                th #
                th Faculty Name
                th Employee ID
                th Leave Type
                th From
                th To
                th Status
                th Action
            tbody
              each leave, i in recentLeaves
                tr(class=leave.isUrgent && leave.status==='Pending' ? 'urgent-row' : '')
                  td= i + 1
                  td= leave.faculty.name
                  td= leave.faculty.employeeId
                  td
                    if leave.isUrgent
                      span.badge.badge-urgent URGENT &nbsp;
                    | #{leave.leaveType}
                  td= new Date(leave.startDate).toLocaleDateString('en-IN')
                  td= new Date(leave.endDate).toLocaleDateString('en-IN')
                  td
                    span(class="badge badge-" + leave.status.toLowerCase())= leave.status
                  td
                    a.btn.btn-default.btn-sm(href="/hod/leave/" + leave._id) Review
  .site-footer
    | Faculty Leave Management System &copy; 2024
